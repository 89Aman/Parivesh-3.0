.git
.gitignore
memories/
README.md
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
Backend/.venv/
Backend/.env
Backend/.env.*
frontend/node_modules/
# frontend/dist is intentionally NOT ignored so Dockerfile.cloudrun can COPY it
# after it has been pre-built by the cloudbuild.yaml npm step.
frontend/.env
frontend/.env.*
frontend/.vite/
*.log
